#!/bin/sh

# SPDX-License-Identifier: MIT
#
# Based on original Entware UBIFS helper
# Enhanced for Keenetic routers
#
# Features:
# - Moves runtime/log/temp directories to tmpfs (RAM)
# - Reduces flash wear on USB/UBIFS storage
# - Helps prevent PID/socket issues with Entware services
# - Adaptive RAM-aware tmpfs sizing
# - BusyBox / ash compatible
#
# Recommended:
# Place as:
#   /opt/etc/init.d/S00ubifs
#
# Author modifications:
#   Saymer / community enhancements

#######################################
# Colors
#######################################

ansi_std="\033[0m"
ansi_red="\033[1;31m"
ansi_green="\033[1;32m"
ansi_yellow="\033[1;33m"
ansi_cyan="\033[1;36m"
ansi_white="\033[1;37m"

#######################################
# Layout
#######################################

COLUMNS="48"

#######################################
# Runtime
#######################################

ACTION="$1"

#######################################
# Directories
#######################################

TMP_DIR="/opt/tmp"
LOG_DIR="/opt/var/log"
RUN_DIR="/opt/var/run"

DIRS="$TMP_DIR $LOG_DIR $RUN_DIR"

#######################################
# Service config
#######################################

ENABLED=yes
DESC="Entware tmpfs optimizer"

#######################################
# PATH
#######################################

PATH="/opt/bin:/opt/sbin:/opt/usr/bin:/opt/usr/sbin:$PATH"

#######################################
# Detect available RAM
#######################################

set_adaptive_sizes() {

    FREE_RAM_KB="$(awk '/MemAvailable/ {print $2}' /proc/meminfo 2>/dev/null)"

    [ -n "$FREE_RAM_KB" ] || \
    FREE_RAM_KB="$(awk '/MemFree/ {print $2}' /proc/meminfo)"

    FREE_RAM_MB=$((FREE_RAM_KB / 1024))

    ###################################
    # RAM profiles
    ###################################

    if [ "$FREE_RAM_MB" -lt 40 ]; then

        PROFILE="low"

        TMP_SIZE="5M"
        LOG_SIZE="2M"
        RUN_SIZE="512k"

    elif [ "$FREE_RAM_MB" -lt 80 ]; then

        PROFILE="medium"

        TMP_SIZE="10M"
        LOG_SIZE="5M"
        RUN_SIZE="1M"

    else

        PROFILE="high"

        TMP_SIZE="20M"
        LOG_SIZE="10M"
        RUN_SIZE="1M"
    fi
}

#######################################
# Select mount size/mode
#######################################

mode_size() {

    SIZE="$RUN_SIZE"
    MODE="1755"

    if [ "$d" = "$TMP_DIR" ]; then

        SIZE="$TMP_SIZE"
        MODE="1777"

    elif [ "$d" = "$LOG_DIR" ]; then

        SIZE="$LOG_SIZE"
    fi
}

#######################################
# Check mount state
#######################################

is_mounted() {
    grep -qs " $1 " /proc/mounts
}

#######################################
# Status check
#######################################

do_check() {

    printf "$ansi_white %-${COLUMNS}s $ansi_std" \
    "Checking tmpfs mounts..."

    if [ "$ENABLED" = "no" ]; then

        printf "$ansi_cyan disabled $ansi_std\n"
        return 0
    fi

    printf "\n"

    for d in $DIRS; do

        printf "$ansi_white %-${COLUMNS}s $ansi_std" "$d"

        if is_mounted "$d"; then
            printf "$ansi_green mounted $ansi_std\n"
        else
            printf "$ansi_red not mounted $ansi_std\n"
        fi
    done
}

#######################################
# Mount tmpfs
#######################################

do_start() {

    [ "$ENABLED" = "yes" ] || return 1

    set_adaptive_sizes

    printf "$ansi_white RAM profile:$ansi_std %s " "$PROFILE"
    printf "(tmp=%s log=%s run=%s)\n" \
    "$TMP_SIZE" "$LOG_SIZE" "$RUN_SIZE"

    for d in $DIRS; do

        [ -d "$d" ] || mkdir -p "$d"

        mode_size

        printf "$ansi_white %-${COLUMNS}s $ansi_std" \
        "Mounting $d ..."

        if is_mounted "$d"; then

            printf "$ansi_yellow already mounted $ansi_std\n"
            continue
        fi

        if mount -t tmpfs \
            -o size="$SIZE",mode="$MODE",noatime,nosuid,nodev \
            tmpfs "$d"; then

            printf "$ansi_green done $ansi_std\n"

        else

            printf "$ansi_red failed $ansi_std\n"
            return 1
        fi
    done
}

#######################################
# Unmount tmpfs
#######################################

do_stop() {

    [ "$ENABLED" = "yes" ] || return 1

    sync

    for d in $DIRS; do

        printf "$ansi_white %-${COLUMNS}s $ansi_std" \
        "Unmounting $d ..."

        if ! is_mounted "$d"; then

            printf "$ansi_yellow not mounted $ansi_std\n"
            continue
        fi

        if umount "$d"; then

            printf "$ansi_green done $ansi_std\n"

        else

            printf "$ansi_red failed $ansi_std\n"
            return 1
        fi
    done
}

#######################################
# Enable autorun
#######################################

do_enable() {

    printf "$ansi_white Enabling $DESC ... $ansi_std"

    if grep -q '^ENABLED=no' "$0"; then

        sed -i 's/^ENABLED=no/ENABLED=yes/' "$0"

        printf "$ansi_green done $ansi_std\n"

    else

        printf "$ansi_yellow already enabled $ansi_std\n"
    fi
}

#######################################
# Disable autorun
#######################################

do_disable() {

    printf "$ansi_white Disabling $DESC ... $ansi_std"

    if grep -q '^ENABLED=yes' "$0"; then

        sed -i 's/^ENABLED=yes/ENABLED=no/' "$0"

        printf "$ansi_green done $ansi_std\n"

    else

        printf "$ansi_yellow already disabled $ansi_std\n"
    fi
}

#######################################
# Main
#######################################

case "$ACTION" in

    start)
        do_start
    ;;

    stop|kill)
        do_stop
    ;;

    restart)
        do_stop
        sleep 1
        do_start
    ;;

    reload)
        do_stop
        sleep 1
        do_start
    ;;

    check|status)
        do_check
    ;;

    enable)
        do_enable
    ;;

    disable)
        do_disable
    ;;

    *)
        echo "Usage: $0 {start|stop|restart|status|enable|disable}"
        exit 1
    ;;

esac

exit 0
