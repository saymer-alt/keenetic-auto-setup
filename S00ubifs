#!/bin/sh

# SPDX-License-Identifier: MIT
#
# Based on original Entware UBIFS helper by Entware team
# Original source: https://pastebin.com/6SyQqPHJ
#
# Enhanced for Keenetic routers by Saymer / community
#
# Features:
#   - Moves runtime/log/temp directories to tmpfs (RAM)
#   - Reduces flash wear on USB/UBIFS storage
#   - Helps prevent PID/socket issues with Entware services
#   - Adaptive RAM-aware tmpfs sizing (low / medium / high profiles)
#   - BusyBox / ash compatible (POSIX sh)
#
# Recommended installation:
#   /opt/etc/init.d/S00ubifs
#   chmod +x /opt/etc/init.d/S00ubifs
#
# Usage:
#   /opt/etc/init.d/S00ubifs {start|stop|restart|reload|status|enable|disable}

#######################################
# Colors for terminal output
#######################################

ansi_std="\033[0m"
ansi_red="\033[1;31m"
ansi_green="\033[1;32m"
ansi_yellow="\033[1;33m"
ansi_cyan="\033[1;36m"
ansi_white="\033[1;37m"

#######################################
# Layout / formatting
#######################################

COLUMNS="48"

#######################################
# Runtime
#######################################

ACTION="$1"

#######################################
# Directories to mount as tmpfs
#######################################

TMP_DIR="/opt/tmp"
LOG_DIR="/opt/var/log"
RUN_DIR="/opt/var/run"

DIRS="$TMP_DIR $LOG_DIR $RUN_DIR"

#######################################
# Service configuration
#######################################

ENABLED=yes
DESC="Entware tmpfs optimizer"

#######################################
# PATH (ensure Entware binaries are found)
#######################################

PATH="/opt/bin:/opt/sbin:/opt/usr/bin:/opt/usr/sbin:$PATH"

#######################################
# Detect available RAM and select profile
#
# Reads MemAvailable (kernel 3.14+) or falls back to MemFree.
# If neither exists, assumes 64 MB as safe default.
# Profiles:
#   low    : < 40 MB free  (minimal tmpfs)
#   medium : < 80 MB free  (balanced tmpfs)
#   high   : >= 80 MB free (default tmpfs)
#######################################

set_adaptive_sizes() {

    # Try MemAvailable first (accounts for caches/buffers)
    FREE_RAM_KB="$(awk '/^MemAvailable:/ {print $2}' /proc/meminfo 2>/dev/null)"

    # Fallback to MemFree on older kernels
    [ -n "$FREE_RAM_KB" ] || \
    FREE_RAM_KB="$(awk '/^MemFree:/ {print $2}' /proc/meminfo 2>/dev/null)"

    # Ultimate fallback: assume 64 MB if /proc/meminfo unreadable
    [ -n "$FREE_RAM_KB" ] || FREE_RAM_KB="65536"

    FREE_RAM_MB=$((FREE_RAM_KB / 1024))

    ###################################
    # Select profile based on free RAM
    ###################################

    if [ "$FREE_RAM_MB" -lt 40 ]; then

        PROFILE="low"
        TMP_SIZE="5M"
        LOG_SIZE="2M"
        RUN_SIZE="512k"

    elif [ "$FREE_RAM_MB" -lt 80 ]; then

        PROFILE="medium"
        TMP_SIZE="10M"
        LOG_SIZE="5M"
        RUN_SIZE="1M"

    else

        PROFILE="high"
        TMP_SIZE="20M"
        LOG_SIZE="10M"
        RUN_SIZE="1M"
    fi
}

#######################################
# Select mount size and mode per directory
#
# Defaults: RUN_SIZE + mode 1755 (owner full, group/others read+execute)
# TMP_DIR:  TMP_SIZE + mode 1777 (sticky bit, world-writable)
# LOG_DIR:  LOG_SIZE + mode 1755
#######################################

mode_size() {

    SIZE="$RUN_SIZE"
    MODE="1755"

    if [ "$d" = "$TMP_DIR" ]; then
        SIZE="$TMP_SIZE"
        MODE="1777"

    elif [ "$d" = "$LOG_DIR" ]; then
        SIZE="$LOG_SIZE"
    fi
}

#######################################
# Check if a directory is already mounted as tmpfs
#
# Uses /proc/mounts (no external dependencies)
#######################################

is_mounted() {
    grep -qs " $1 " /proc/mounts
}

#######################################
# Status check
#
# Prints mount state for each managed directory.
# If ENABLED=no, prints "disabled" and exits.
#######################################

do_check() {

    printf "$ansi_white %-${COLUMNS}s $ansi_std" \
    "Checking tmpfs mounts..."

    if [ "$ENABLED" = "no" ]; then
        printf "$ansi_cyan disabled $ansi_std\n"
        return 0
    fi

    printf "\n"

    for d in $DIRS; do

        printf "$ansi_white %-${COLUMNS}s $ansi_std" "$d"

        if is_mounted "$d"; then
            printf "$ansi_green mounted $ansi_std\n"
        else
            printf "$ansi_red not mounted $ansi_std\n"
        fi
    done
}

#######################################
# Mount tmpfs directories
#
# 1. Detects RAM profile
# 2. Ensures directories exist
# 3. Mounts with size/mode/noatime/nosuid/nodev
#    - noatime  : reduces flash/RAM writeback
#    - nosuid   : ignores setuid binaries
#    - nodev    : prevents device files
#######################################

do_start() {

    [ "$ENABLED" = "yes" ] || return 1

    set_adaptive_sizes

    printf "$ansi_white RAM profile:$ansi_std %s " "$PROFILE"
    printf "(tmp=%s log=%s run=%s)\n" \
    "$TMP_SIZE" "$LOG_SIZE" "$RUN_SIZE"

    for d in $DIRS; do

        # Create directory if missing (e.g. after factory reset)
        if [ ! -d "$d" ]; then
            mkdir -p "$d" || {
                printf "$ansi_red failed to create $d $ansi_std\n"
                return 1
            }
        fi

        mode_size

        printf "$ansi_white %-${COLUMNS}s $ansi_std" \
        "Mounting $d ..."

        if is_mounted "$d"; then
            printf "$ansi_yellow already mounted $ansi_std\n"
            continue
        fi

        if mount -t tmpfs \
            -o size="$SIZE",mode="$MODE",noatime,nosuid,nodev \
            tmpfs "$d"; then

            printf "$ansi_green done $ansi_std\n"

        else
            printf "$ansi_red failed $ansi_std\n"
            return 1
        fi
    done
}

#######################################
# Unmount tmpfs directories
#
# 1. Syncs filesystem buffers
# 2. Unmounts each directory
# 3. Skips if not mounted
#######################################

do_stop() {

    [ "$ENABLED" = "yes" ] || return 1

    # Flush pending writes before unmounting
    sync

    for d in $DIRS; do

        printf "$ansi_white %-${COLUMNS}s $ansi_std" \
        "Unmounting $d ..."

        if ! is_mounted "$d"; then
            printf "$ansi_yellow not mounted $ansi_std\n"
            continue
        fi

        if umount "$d"; then
            printf "$ansi_green done $ansi_std\n"
        else
            printf "$ansi_red failed $ansi_std\n"
            return 1
        fi
    done
}

#######################################
# Enable autorun
#
# Modifies this script in-place to set ENABLED=yes.
# Uses robust sed pattern (handles optional whitespace).
#######################################

do_enable() {

    printf "$ansi_white Enabling $DESC ... $ansi_std"

    if grep -qE '^[[:space:]]*ENABLED[[:space:]]*=[[:space:]]*no' "$0"; then

        sed -i 's/^[[:space:]]*ENABLED[[:space:]]*=[[:space:]]*no/ENABLED=yes/' "$0"

        printf "$ansi_green done $ansi_std\n"

    else
        printf "$ansi_yellow already enabled $ansi_std\n"
    fi
}

#######################################
# Disable autorun
#
# Modifies this script in-place to set ENABLED=no.
#######################################

do_disable() {

    printf "$ansi_white Disabling $DESC ... $ansi_std"

    if grep -qE '^[[:space:]]*ENABLED[[:space:]]*=[[:space:]]*yes' "$0"; then

        sed -i 's/^[[:space:]]*ENABLED[[:space:]]*=[[:space:]]*yes/ENABLED=no/' "$0"

        printf "$ansi_green done $ansi_std\n"

    else
        printf "$ansi_yellow already disabled $ansi_std\n"
    fi
}

#######################################
# Main dispatcher
#######################################

case "$ACTION" in

    start)
        do_start
    ;;

    stop|kill)
        do_stop
    ;;

    restart)
        do_stop
        sleep 1
        do_start
    ;;

    reload)
        do_stop
        sleep 1
        do_start
    ;;

    check|status)
        do_check
    ;;

    enable)
        do_enable
    ;;

    disable)
        do_disable
    ;;

    *)
        echo "Usage: $0 {start|stop|restart|reload|status|enable|disable}"
        exit 1
    ;;

esac

exit 0
